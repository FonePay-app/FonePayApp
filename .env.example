# ============================================
# FONEPAY CREDENTIALS
# ============================================
# Merchant Code (PID) proporcionado por FonePay
FONEPAY_PID=

# Shared Secret Key — NUNCA commitear al repo
FONEPAY_SECRET=

# Ambiente: test | live
FONEPAY_MODE=test

# ============================================
# GOHIGHLEVEL OAUTH2
# ============================================
# Obtener desde: marketplace.gohighlevel.com/app-dashboard
GHL_CLIENT_ID=
GHL_CLIENT_SECRET=
GHL_REDIRECT_URI=https://fonepay-nepal.vercel.app/api/oauth/callback

# ============================================
# APP CONFIG
# ============================================
APP_BASE_URL=https://TU-APP.vercel.app
